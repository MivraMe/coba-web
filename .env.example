# Application
APP_PORT=3000
NODE_ENV=production
REFRESH_INTERVAL_MINUTES=5

# Superadmin — compte administrateur système créé automatiquement au démarrage
# Si ces variables sont définies, le compte est créé (ou promu superadmin) au boot
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Base de données
DB_NAME=cobadb
DB_USER=cobauser
DB_PASSWORD=changeme_mot_de_passe_bd

# Sécurité — générer avec : openssl rand -hex 32
JWT_SECRET=changeme_secret_jwt_au_moins_32_caracteres_long
ENCRYPTION_KEY=changeme_generer_avec_openssl_rand_hex_32

# Portail Collège Esther-Blondin
PORTAL_BASE_URL=https://portail.college-eb.com/api

# SMTP (courriel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=changeme_mot_de_passe_smtp
SMTP_FROM=Notes Esther-Blondin <noreply@example.com>

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_PHONE_NUMBER=+15141234567
